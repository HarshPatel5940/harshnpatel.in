---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
    <div class="pb-12 mt-5">
        <div class="text-xl py-1">Hey there 👋</div>
        <div class="text-5xl font-bold">I'm Harsh Patel</div>
        <div class="text-3xl py-3 font-bold">
            Crafting seamless backends, Bots and Discord Servers
        </div>
        <div class="py-2">
            <text class="text-lg">
                I am a senior year undergrad dedicated to the pursuit of a Computer
                Science and Engineering degree, backed by a formidable
                <b>four-year</b> freelance tenure as a Backend and Bot Developer.
                Currently, I write code and have fun in <b></b>Golang & TypeScript</b>. My relentless
                enthusiasm for cutting-edge technologies and my
                commitment to <b>open source initiatives</b> propel my journey in this
                field.<br />
                <br />

                As a Freelance Developer, I have had the privilege of collaborating with over <b>30 clients</b>,
                both national and <b>international</b>, on projects spanning bot development, automation, and web development.
                <br /><br />

                For further inquiries or collaboration opportunities, please do
                not hesitate to reach out to me at
                <a href="mailto:hi@harshnpatel.in" target="blank=" class="text-blue-500 hover:underline">
                    hi@harshnpatel.in</a> or feel free to <a
                    href="https://cal.com/harshnpatel" target="_blank" class="text-blue-500 hover:underline">
                    book a call here
                    </a  
                >.
            </text>
        </div>
        <div class="flex flex-col md:flex-row mx-3 md:mx-0 gap-2 mt-8">
            <a
                class="btn flex"
                href="/Harsh_Nikul_Patel_Resume.pdf"
                download="Harsh_Nikul_Patel.pdf"
                target="_blank"
            >
                Download CV!</a
            >
            <a
                href="https://linkedin.com/in/HarshPatel5940"
                target="_blank"
                class="btn btn-outline flex"
            >
                My Linkedin
            </a>
            <a
                href="https://github.com/HarshPatel5940"
                target="_blank"
                class="btn btn-outline flex"
            >
                My Github
            </a>
            <a
                href="https://fiverr.com/harshpatel5940"
                target="_blank"
                class="btn btn-outline flex"
            >
                My Fiverr
            </a>
        </div>
    </div>

    <div>
        <div class="text-3xl w-full font-bold mb-2">My Projects {"</>"}</div>
    </div>

    <HorizontalCard
        title="CodeFlick"
        desc="Open-source alternative to PasteBin built with Go"
        url="https://github.com/HarshPatel5940/CodeFlick"
        badge="NEW"
        tags={["Go", "HTML/CSS", "JavaScript", "SQLite", "Docker"]}
    />
    <HorizontalCard
    title="DHB-V2"
    desc="Multi-Utility Discord Bot with advanced features. Latest version of the original 'Discord Helper Bot\'"
    url="https://github.com/HarshPatel5940/dhb-v2"
    badge="New "
    tags={["TypeScript", "Discord.js", "MongoDB", "Node.js"]}
    />
    <HorizontalCard
        title="EzMs-Frontend"
        img="https://repository-images.githubusercontent.com/733384623/1292b76c-542b-46d1-89fb-0e1840f67e50"
        desc="A Clean, simple Frontend made to manage the CMS API using React and Typescript"
        url="https://github.com/harshpatel5940/ezms-frontend"
        tags={["TypeScript", "React", "CMS", "Website", "Frontend"]}
    />
    <HorizontalCard
        title="EzMs-Backend"
        img="https://repository-images.githubusercontent.com/654061696/0dac8f4c-53e9-4ca9-823e-df9afd606b4d"
        desc="Robust Backend for an Content Management System made using NestJs and TypeScript"
        url="https://github.com/harshpatel5940/ezms-backend"
        tags={["TypeScript", "NestJs", "CMS", "API", "PostgreSQL"]}
    />
    <div>
        <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
    </div>

    {
        last_posts.map((post) => (
            <>
                <HorizontalCard
                    title={post.data.title}
                    img={post.data.heroImage}
                    desc={post.data.description}
                    url={"/blog/" + post.slug}
                    target="_self"
                    badge={post.data.badge}
                />
                <div class="divider my-0" />
            </>
        ))
    }
</BaseLayout>
